# Copia questo file in `.env.local` sulla macchina universitaria Windows.
# `.env.local` viene letto dopo `.env` e sovrascrive i path specifici della macchina.

# Esempio: modifica il path in base alla posizione reale della cartella biocube sul disco SSD F:.
# Su Windows usa slash `/` per evitare problemi con i backslash.
BIOCUBE_DIR=F:/biomap_thesis/data/biocube

# Output locali generati dal backend FastAPI.
PROJECT_OUTPUT_DIR=outputs/local_preview

# Opzionale: lascia vuoto o modifica solo se usi modelli locali da un'altra cartella.
BIOANALYST_MODEL_DIR=models
